{
    "name": "@orbitforge/orbitforge-draw-controls",
    "version": "0.0.1",
    "description": "Drawing controls module for the orbitforge library",
    "main": "lib/src/index.js",
    "typings": "lib/src/index",
    "exports": {
        ".": {
            "import": "./lib/src/index.js",
            "require": "./lib/src/index.js"
        },
        "./*": {
            "import": "./lib/src/*",
            "require": "./lib/src/*"
        },
        "./package.json": "./package.json"
    },
    "directories": {
        "test": "test"
    },
    "scripts": {
        "test": "cross-env mocha --require source-map-support/register $EXTRA_MOCHA_ARGS ./test/*.js",
        "build": "cross-env tsc --build $EXTRA_TSC_ARGS",
        "prepare": "cross-env tsc --build $EXTRA_TSC_ARGS --force"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/YaeSakura923/orbitforge.git",
        "directory": "@orbitforge/orbitforge-draw-controls"
    },
    "author": {
        "name": "orbitforge contributors",
        "url": "https://orbitforge.dev"
    },
    "license": "Apache-2.0",
    "dependencies": {},
    "devDependencies": {
        "@orbitforge/orbitforge-test-utils": "workspace:*",
        "@types/three": "catalog:",
        "@types/earcut": "catalog:",
        "three": "catalog:",
        "typescript": "catalog:",
        "earcut": "catalog:"
    },
    "peerDependencies": {
        "three": "catalog:"
    },
    "private": true
}
