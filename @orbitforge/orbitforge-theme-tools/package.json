{
    "name": "@orbitforge/orbitforge-theme-tools",
    "version": "0.0.1",
    "description": "Tools for orbitforge-theme optimiziation.",
    "bin": {
        "orbitforge-theme-optimizer": "lib/cli-build-theme.js"
    },
    "scripts": {
        "build": "tsc --build",
        "watch": "tsc --build -w",
        "buildTheme": "ts-node src/cli-build-theme.ts",
        "prepare": "cross-env tsc --build $EXTRA_TSC_ARGS --force"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/YaeSakura923/orbitforge.git",
        "directory": "@orbitforge/orbitforge-theme-tools"
    },
    "author": {
        "name": "orbitforge contributors",
        "url": "https://orbitforge.dev"
    },
    "license": "Apache-2.0",
    "keywords": [
        "here",
        "orbitforge",
        "theme"
    ],
    "dependencies": {
        "commander": "catalog:",
        "glob": "catalog:",
        "path": "catalog:"
    },
    "devDependencies": {
        "ts-node": "catalog:",
        "typescript": "catalog:"
    },
    "private": true
}
