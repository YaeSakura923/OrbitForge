{
    "name": "@orbitforge/orbitforge-geojson-datasource",
    "version": "0.0.1",
    "description": "Provides support for GeoJSON datasource",
    "main": "./lib/src/index.js",
    "typings": "./lib/src/index",
    "worker": {
        "name": "@orbitforge/orbitforge-geojson-datasource-worker",
        "main": "index-worker.js"
    },
    "exports": {
        ".": {
            "import": "./lib/src/index.js",
            "require": "./lib/src/index.js"
        },
        "./*": {
            "import": "./lib/src/*",
            "require": "./lib/src/*"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "cross-env tsc --build $EXTRA_TSC_ARGS",
        "test": "cross-env mocha --require source-map-support/register $EXTRA_MOCHA_ARGS ./test/*.js",
        "prepare": "cross-env tsc --build $EXTRA_TSC_ARGS --force"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/YaeSakura923/orbitforge.git",
        "directory": "@orbitforge/orbitforge-geojson-datasource"
    },
    "author": {
        "name": "orbitforge contributors",
        "url": "https://orbitforge.dev"
    },
    "license": "Apache-2.0",
    "dependencies": {},
    "devDependencies": {
        "@orbitforge/orbitforge-test-utils": "workspace:*",
        "@types/chai": "catalog:",
        "@types/mocha": "catalog:",
        "@types/node": "catalog:",
        "@types/three": "catalog:",
        "chai": "catalog:",
        "cross-env": "catalog:",
        "mocha": "catalog:",
        "sinon": "catalog:",
        "source-map-support": "catalog:",
        "three": "catalog:",
        "typescript": "catalog:"
    },
    "private": true
}
